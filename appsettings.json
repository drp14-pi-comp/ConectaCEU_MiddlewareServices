{
  "App": {
    "Name": "ConectaCEU",
    "Version": "0.1.0",
    "Environment": "Development"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    }
  },
  "AllowedHosts": "*",
  "Pagination": {
    "DefaultPageSize": 10,
    "MaxPageSize": 50
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:8000"
    ]
  },
  "MySQL": {
    "Charset": "utf8mb4",
    "Collation": "utf8mb4_unicode_ci",
    "Engine": "InnoDB",
    "Timezone": "+00:00"
  }
}